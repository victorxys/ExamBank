.no-margin {
  margin-top: 0;
}

.picker-field {
  min-height: 84rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border-radius: 10rpx;
  border: 1rpx solid #d8e1e8;
  background: #fff;
  color: #0f172a;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d8e1e8;
  background: #fff;
  color: #0f172a;
  font-size: 27rpx;
  line-height: 40rpx;
}

.success-card {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #0f9f8f;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}
