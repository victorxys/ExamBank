<view class="page">
  <view class="hero">
    <view class="hero-head">
      <view class="logo-box"><image class="logo" src="https://images.mengyimengsao.com/miniprogram/logo.png" mode="aspectFit" /></view>
      <view class="hero-copy">
        <view class="hero-title">下户总结</view>
        <view class="hero-desc">{{contract.customer_name || '客户'}} · {{contract.date_range || ''}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title no-margin">总结信息</view>
    <view class="field">
      <text class="label">下户日期</text>
      <picker mode="date" value="{{form.exit_date}}" bindchange="onDateChange">
        <view class="picker-field">{{form.exit_date || '请选择下户日期'}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">服务中的经验与亮点</text>
      <textarea class="textarea" maxlength="800" placeholder="例如客户习惯、宝宝/老人照护要点、值得继续保持的做法" value="{{form.learned}}" data-field="learned" bindinput="onInput"></textarea>
    </view>
    <view class="field">
      <text class="label">后续可改进事项</text>
      <textarea class="textarea" maxlength="800" placeholder="例如沟通、物品交接、服务细节等" value="{{form.improved}}" data-field="improved" bindinput="onInput"></textarea>
    </view>
  </view>

  <view wx:if="{{submitted}}" class="success-card">已保存下户总结，可继续修改后重新提交。</view>
  <button class="submit-btn" loading="{{loading}}" bindtap="submit">{{submitted ? '更新下户总结' : '保存下户总结'}}</button>
</view>
