.signature-viewport {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  background: #ffffff;
}

.signature-panel {
  position: fixed;
  transform-origin: top left;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  overflow: hidden;
}

.signature-toolbar {
  flex: none;
  box-sizing: border-box;
  padding: 0 18px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  border-bottom: 1px solid #e2e8f0;
  background: #f8fafc;
}

.toolbar-title {
  color: #64748b;
  font-size: 15px;
  font-weight: 800;
  line-height: 1;
}

.signature-actions {
  flex: none;
  box-sizing: border-box;
  padding: 8px 20px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6px;
  border-top: 1px solid #e2e8f0;
  background: #f8fafc;
}

.tool-btn,
.confirm-btn {
  box-sizing: border-box;
  width: 64px;
  height: 30px;
  margin: 0;
  padding: 0;
  border-radius: 7px;
  font-size: 15px;
  font-weight: 900;
  line-height: 30px;
  text-align: center;
}

.tool-btn {
  border: 1px solid #cbd5e1;
  background: #ffffff;
  color: #475569;
}

.confirm-btn {
  width: 72px;
  border: 0;
  background: #0f766e;
  color: #ffffff;
}

.tool-btn-hover {
  background: #f1f5f9;
}

.confirm-btn-hover {
  background: #0d9488;
}

.canvas-wrap {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
}

.signature-canvas {
  flex: none;
  display: block;
  background: #ffffff;
}

.guide-wrap {
  position: relative;
  flex: none;
  background: #ffffff;
}

.guide-line {
  position: absolute;
  left: 24px;
  right: 24px;
  top: 5px;
  border-bottom: 1px dashed #cbd5e1;
  pointer-events: none;
}

.guide-text {
  position: absolute;
  left: 24px;
  top: 11px;
  color: #94a3b8;
  font-size: 12px;
  font-weight: 700;
  line-height: 1;
  pointer-events: none;
}
