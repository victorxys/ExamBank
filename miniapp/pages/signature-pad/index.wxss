.signature-page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

.signature-toolbar {
  height: 44rpx;
  flex: none;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  border-bottom: 1rpx solid #e2e8f0;
  background: #f8fafc;
}

.toolbar-title {
  flex: 1;
  min-width: 0;
  color: #64748b;
  font-size: 17rpx;
  font-weight: 800;
}

.toolbar-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tool-btn,
.confirm-btn {
  width: 88rpx;
  height: 34rpx;
  margin: 0;
  padding: 0;
  border-radius: 7rpx;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.tool-btn {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #475569;
}

.confirm-btn {
  width: 104rpx;
  border: 0;
  background: #0f766e;
  color: #ffffff;
}

.canvas-wrap {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
}

.signature-canvas {
  width: 100%;
  flex: none;
}

.guide-wrap {
  position: relative;
  flex: none;
  height: 56rpx;
  background: #ffffff;
}

.guide-line {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  top: 8rpx;
  border-bottom: 3rpx dashed #cbd5e1;
  pointer-events: none;
}

.guide-text {
  position: absolute;
  left: 44rpx;
  top: 18rpx;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 700;
  pointer-events: none;
}
