<view class="signature-page">
  <view class="signature-toolbar">
    <view class="toolbar-title">签名区域</view>
    <view class="toolbar-actions">
      <button class="tool-btn" bindtap="cancel">取消</button>
      <button class="tool-btn" bindtap="clearSignature">清除</button>
      <button class="confirm-btn" bindtap="confirm">确认</button>
    </view>
  </view>
  <view class="canvas-wrap" style="width: {{canvasWidth}}px;">
    <canvas
      class="signature-canvas"
      style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
      canvas-id="signaturePad"
      disable-scroll="true"
      bindtouchstart="touchStart"
      bindtouchmove="touchMove"
      bindtouchend="touchEnd"
    ></canvas>
    <view class="guide-wrap">
      <view class="guide-line"></view>
      <view class="guide-text">签名区域</view>
    </view>
  </view>
</view>
