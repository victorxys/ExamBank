.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow-x: hidden;
}

.login-logo {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.12);
}

.login-logo-img {
  width: 104rpx;
  height: 104rpx;
}

.login-title {
  text-align: center;
  font-size: 44rpx;
  line-height: 54rpx;
  font-weight: 900;
  color: #0f172a;
}

.login-desc {
  width: 560rpx;
  max-width: 100%;
  margin: 18rpx auto 24rpx;
  text-align: center;
  font-size: 27rpx;
  line-height: 42rpx;
  color: #64748b;
}

.login-btn {
  margin-top: 24rpx;
}

.role-tabs {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin: 12rpx 0 24rpx;
  width: 100%;
  min-width: 0;
}

.role-tab {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 1rpx solid #d8e1e8;
  border-radius: 12rpx;
  background: #fff;
  color: #475569;
  font-size: 25rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.role-tab.active {
  border-color: #0f9f8f;
  background: #e7f7f4;
  color: #04786d;
}
