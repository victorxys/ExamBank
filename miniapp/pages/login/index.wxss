.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 0;
  background: #fbfffd;
}

.login-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.login-content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 90rpx 90rpx calc(62rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: stretch;
  box-sizing: border-box;
}

.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-logo {
  width: 145rpx;
  height: 145rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.14);
  overflow: hidden;
}

.login-logo-img {
  width: 125rpx;
  height: 125rpx;
  border-radius: 20rpx;
}

.login-title {
  margin-top: 70rpx;
  text-align: center;
  font-size: 50rpx;
  line-height: 72rpx;
  font-weight: 950;
  color: #0e1b31;
  white-space: nowrap;
}

.login-subtitle {
  margin-top: 24rpx;
  text-align: center;
  color: #6b7c90;
  font-size: 24;
  line-height: 42rpx;
  font-weight: 700;
  white-space: nowrap;
}

.feature-panel {
  margin-top: 102rpx;
  padding: 18rpx 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 22rpx 50rpx rgba(15, 23, 42, 0.11);
}

.feature-card {
  min-width: 0;
  min-height: 232rpx;
  padding: 4rpx 14rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  position: relative;
}

.feature-card:nth-child(1),
.feature-card:nth-child(2) {
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.28);
}

.feature-card:nth-child(1),
.feature-card:nth-child(3) {
  border-right: 1rpx solid rgba(148, 163, 184, 0.28);
}

.feature-icon {
  width: 160rpx;
  height: 138rpx;
}

.feature-title {
  margin-top: 2rpx;
  color: #122548;
  font-size: 26rpx;
  line-height: 42rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
}

.feature-desc {
  margin-top: 8rpx;
  color: #6b7c90;
  font-size: 22rpx;
  line-height: 31rpx;
  font-weight: 650;
  text-align: center;
  white-space: nowrap;
}

.login-actions {
  margin-top: 80rpx;
  width: 560rpx;
  align-self: center;
  padding: 0;
  transform: translateY(34rpx);
}

.dev-card {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.login-btn {
  width: 100%;
  max-width: none;
  height: 88rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #16c0ac, #079987);
  color: #fff;
  font-size: 32rpx;
  line-height: 54rpx;
  font-weight: 950;
  box-shadow: 0 18rpx 34rpx rgba(15, 159, 143, 0.32);
}

.login-btn::after {
  border: 0;
}

.login-tip {
  margin-top: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.tip-line {
  width: 54rpx;
  height: 2rpx;
  background: rgba(100, 116, 139, 0.26);
}

.tip-text {
  color: #6b7280;
  font-size: 25rpx;
  line-height: 34rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
}
