.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow-x: hidden;
  padding: 96rpx 34rpx 72rpx;
}

.login-brand {
  padding-top: 52rpx;
}

.login-logo {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.1);
}

.login-logo-img {
  width: 96rpx;
  height: 96rpx;
}

.login-title {
  text-align: center;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 900;
  color: #0f172a;
}

.login-desc {
  width: 560rpx;
  max-width: 100%;
  margin: 20rpx auto 0;
  text-align: center;
  font-size: 26rpx;
  line-height: 44rpx;
  color: #64748b;
}

.login-actions {
  width: 100%;
  padding-bottom: 22rpx;
}

.dev-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.login-btn {
  height: 94rpx;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 159, 143, 0.22);
}
