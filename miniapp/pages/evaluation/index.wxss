.evaluation-page {
  padding-bottom: calc(210rpx + env(safe-area-inset-bottom));
}

.no-margin {
  margin-top: 0;
}

.eval-hero {
  padding: 28rpx;
  border-radius: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #16a394, #4bb58b);
  box-shadow: 0 18rpx 40rpx rgba(16, 94, 82, 0.12);
}

.summary-card,
.form-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-main {
  min-width: 0;
  flex: 1;
}

.summary-label,
.section-desc,
.counter {
  color: #718096;
  font-size: 23rpx;
  line-height: 32rpx;
}

.summary-title {
  margin-top: 6rpx;
  color: #0f172a;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.summary-desc {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-word;
}

.summary-score {
  flex: none;
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  border-radius: 26rpx;
  background: #fff7ed;
  color: #f59e0b;
}

.summary-score-num {
  font-size: 52rpx;
  line-height: 108rpx;
  font-weight: 950;
}

.summary-score-unit {
  margin-left: 4rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  margin: 0;
  color: #0f172a;
  font-size: 31rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.section-desc {
  margin-top: 6rpx;
}

.rating-pill {
  flex: none;
  margin-top: 2rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 850;
}

.star-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
}

.star {
  width: 100%;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #cbd5e1;
  font-size: 44rpx;
  line-height: 1;
}

.star.active {
  background: #fff7ed;
  color: #f59e0b;
}

.tag-section {
  margin-top: 20rpx;
}

.tag-section-title {
  color: #334155;
  font-size: 25rpx;
  line-height: 34rpx;
  font-weight: 850;
}

.tag-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.tag-chip {
  min-width: 0;
  min-height: 58rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tag-chip.active {
  background: #e5faf6;
  color: #0f766e;
}

.tag-chip.improve.active {
  background: #fff7ed;
  color: #c2410c;
}

.quick-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
}

.quick-chip {
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  line-height: 36rpx;
  border: 1rpx solid #e2e8f0;
}

.comment-input {
  width: 100%;
  min-height: 220rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d8e1e8;
  background: #fff;
  color: #0f172a;
  font-size: 26rpx;
  line-height: 40rpx;
}

.success-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 800;
  text-align: center;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(237, 245, 242, 0.94);
  border-top: 1rpx solid rgba(203, 213, 225, 0.7);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #0f9f8f;
  color: #fff;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 900;
}
