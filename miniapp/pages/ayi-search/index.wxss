.ayi-search-page {
  padding: 0 28rpx 56rpx;
}

.ayi-hero {
  min-height: 300rpx;
  margin: 0 -28rpx;
  padding: 54rpx 56rpx 34rpx;
  border-radius: 0 0 34rpx 34rpx;
  box-shadow: none;
}

.ayi-hero .design-hero-content {
  max-width: 420rpx;
}

.ayi-hero .design-hero-title {
  color: #0d6d76;
}

.search-panel {
  margin-top: -18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-wrap {
  min-width: 0;
  flex: 1;
  height: 76rpx;
  position: relative;
  border: 1rpx solid #dce6eb;
  border-radius: 18rpx;
  background: #fbfdff;
  overflow: hidden;
}

.search-symbol-img {
  position: absolute;
  left: 22rpx;
  top: 18rpx;
  width: 38rpx;
  height: 38rpx;
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 64rpx 0 72rpx;
  color: #142033;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-btn {
  margin: 0;
  padding: 0;
  width: 132rpx;
  flex: 0 0 132rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #fff;
  background: linear-gradient(135deg, #14cdb8, #029f92);
  box-shadow: 0 12rpx 24rpx rgba(6, 166, 149, 0.2);
}

.search-btn::after {
  border: 0;
}

.clear-btn {
  position: absolute;
  right: 14rpx;
  top: 16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  overflow: hidden;
}

.clear-icon-img {
  width: 100%;
  height: 100%;
}

.filter-grid {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid #e5eef2;
  border-radius: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.picker-line {
  min-width: 0;
  height: 68rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  background: #f7fbfd;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #142033;
  font-size: 25rpx;
  font-weight: 900;
}

.picker-icon-img {
  width: 32rpx;
  height: 32rpx;
  flex: none;
}

.picker-label {
  flex: none;
  color: #142033;
}

.picker-value {
  min-width: 0;
  flex: 1;
  color: #33435a;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow-img {
  flex: none;
  width: 28rpx;
  height: 28rpx;
}

.chip-section {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chip-title {
  width: 100rpx;
  flex: 0 0 100rpx;
  color: #142033;
  font-size: 26rpx;
  line-height: 52rpx;
  font-weight: 900;
  white-space: nowrap;
  display: flex;
  align-items: center;
}

.chip-icon-img {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex: none;
}

.chip-scroll {
  min-width: 0;
  flex: 1;
  white-space: nowrap;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce5ec;
  background: #fff;
  color: #526177;
  font-size: 25rpx;
  font-weight: 800;
  vertical-align: top;
}

.chip.active {
  border-color: #08a895;
  background: #e9fbf7;
  color: #008d80;
}

.filter-footer {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf2f5;
  display: flex;
  justify-content: flex-end;
  color: #08a895;
  font-size: 25rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.reset-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.reset-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.ayi-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  display: flex;
  gap: 22rpx;
  align-items: center;
}

.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 18rpx;
  background: #dcefe9;
  flex-shrink: 0;
}

.ayi-main {
  min-width: 0;
  flex: 1;
}

.ayi-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.ayi-name {
  color: #142033;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.ayi-type {
  min-width: 0;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: #dbf7f1;
  color: #009887;
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ayi-meta {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
  color: #526177;
  font-size: 25rpx;
  line-height: 34rpx;
  font-weight: 600;
}

.ayi-summary {
  margin-top: 8rpx;
  color: #4b5d76;
  font-size: 25rpx;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.arrow-img {
  flex: none;
  width: 44rpx;
  height: 44rpx;
}

.empty {
  margin-top: 28rpx;
  padding: 48rpx 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #142033;
}

.empty-desc,
.loading-more {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #718198;
  text-align: center;
}

.fallback-logout {
  margin: 40rpx 0 10rpx;
  color: #8ea0b4;
  font-size: 23rpx;
  line-height: 34rpx;
  text-align: center;
}
