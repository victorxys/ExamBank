<view class="page">
  <view class="hero">
    <view class="hero-head">
      <view class="logo-box"><image class="logo" src="https://images.mengyimengsao.com/miniprogram/logo.png" mode="aspectFit" /></view>
      <view class="hero-copy">
        <view class="hero-title">{{employee.name || '服务人员'}}，您好</view>
        <view class="hero-desc">处理合同签署，填写并提交月度考勤。</view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">待处理</view>
    <view class="todo-count">{{todoCount}} 项</view>
  </view>

  <block wx:for="{{pendingContracts}}" wx:key="id">
    <view class="action-card" data-token="{{item.employee_signing_token}}" bindtap="goContractSign">
      <view class="action-main">
        <view class="action-icon">签</view>
        <view class="action-content">
          <view class="action-title">{{item.type_label}}待签署</view>
          <view class="action-desc">{{item.customer_name || '客户'}} · {{item.start_date_text}} 开始</view>
        </view>
      </view>
      <view class="todo-badge">待签</view>
    </view>
  </block>

  <block wx:for="{{attendanceForms}}" wx:key="id">
    <view class="action-card" data-id="{{item.id}}" bindtap="goAttendanceFill">
      <view class="action-main">
        <view class="action-icon">勤</view>
        <view class="action-content">
          <view class="action-title">{{item.month || '-'}} 月考勤{{item.status === 'employee_confirmed' ? '待客户确认' : '待填写'}}</view>
          <view class="action-desc">{{item.customer_name || '客户'}} · {{item.date_range}}</view>
        </view>
      </view>
      <view class="todo-badge teal">{{item.status === 'employee_confirmed' ? '已提交' : '待填'}}</view>
    </view>
  </block>

  <view wx:if="{{overviewLoaded && todoCount === 0}}" class="empty">
    <view class="empty-title">暂无待办</view>
    <view class="empty-desc">待签合同和待填写考勤会显示在这里。</view>
  </view>

  <view class="section-head">
    <view class="section-title">履行中合同</view>
    <button class="link-btn" bindtap="goContracts">全部合同</button>
  </view>

  <block wx:for="{{activeContracts}}" wx:key="id">
    <view class="contract-card" data-id="{{item.id}}" bindtap="goContractDetail">
      <view class="contract-top">
        <view>
          <view class="contract-title">{{item.type_label || '服务合同'}}</view>
          <view class="contract-desc">{{item.customer_name || '客户'}} · {{item.date_range}}</view>
        </view>
        <view class="chip">{{item.status_text}}</view>
      </view>
      <view class="contract-foot">
        <text>{{item.signing_status_text}}</text>
        <text>›</text>
      </view>
    </view>
  </block>

  <view wx:if="{{overviewLoaded && activeContracts.length === 0}}" class="empty">
    <view class="empty-title">暂无正在履行合同</view>
    <view class="empty-desc">服务中的合同会显示在这里。</view>
  </view>
</view>
