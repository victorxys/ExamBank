.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.todo-count {
  margin-top: 32rpx;
  color: #0f9f8f;
  font-size: 24rpx;
  font-weight: 800;
}

.link-btn {
  margin-top: 32rpx;
  margin-left: auto;
  color: #0f9f8f;
  background: transparent;
  font-size: 24rpx;
  font-weight: 800;
}

.contract-section-head {
  position: relative;
}

.contract-section-head .link-btn {
  position: absolute;
  right: 0;
  bottom: 18rpx;
  margin-top: 0;
  width: 150rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  text-align: right;
  line-height: 48rpx;
}

.action-card,
.contract-card,
.tool-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.action-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  overflow: hidden;
}

.tool-card {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.tool-main {
  min-width: 0;
  flex: 1;
  display: flex;
  gap: 18rpx;
}

.tool-icon {
  background: #14b8a6;
}

.tool-arrow {
  color: #94a3b8;
  font-size: 42rpx;
  line-height: 72rpx;
}

.action-main {
  min-width: 0;
  flex: 1;
  display: flex;
  gap: 18rpx;
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: #0f9f8f;
  overflow: hidden;
}

.contract-sign-icon,
.attendance-icon {
  background: #0f9f8f;
}

.action-icon-img {
  width: 46rpx;
  height: 46rpx;
}

.action-content {
  min-width: 0;
  flex: 1;
}

.action-title,
.contract-title {
  min-width: 0;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 800;
  color: #0f172a;
  word-break: break-word;
}

.action-desc,
.contract-desc {
  min-width: 0;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #64748b;
  word-break: break-word;
}

.todo-badge {
  flex-shrink: 0;
  max-width: 116rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fffbeb;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.todo-badge.teal {
  background: #ecfdfa;
  color: #0f766e;
}

.quick-entry-card {
  margin: 18rpx 0 28rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 16rpx;
  background: #f0fdfa;
  border: 1rpx solid #99f6e4;
}

.quick-entry-main {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.quick-entry-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 14rpx;
  background: #0f9f8f;
  overflow: hidden;
}

.quick-entry-icon-img {
  width: 42rpx;
  height: 42rpx;
}

.quick-entry-content {
  min-width: 0;
  flex: 1;
}

.quick-entry-title {
  font-size: 27rpx;
  line-height: 36rpx;
  font-weight: 900;
  color: #0f172a;
}

.quick-entry-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 32rpx;
  color: #0f766e;
}

.quick-entry-arrow {
  flex-shrink: 0;
  color: #0f766e;
  font-size: 38rpx;
  font-weight: 700;
}

.contract-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  min-width: 0;
}

.contract-top > view:first-child {
  min-width: 0;
  flex: 1;
}

.contract-foot {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #dbe4ea;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #64748b;
}
