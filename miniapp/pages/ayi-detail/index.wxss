.ayi-detail-page {
  padding: 32rpx 28rpx 58rpx;
}

.profile-hero {
  min-height: 234rpx;
  padding: 34rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(220, 249, 244, 0.82);
  display: flex;
  gap: 28rpx;
  align-items: center;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-avatar {
  width: 154rpx;
  height: 154rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  background: #ccece5;
  flex-shrink: 0;
  box-shadow: 0 14rpx 34rpx rgba(32, 121, 111, 0.12);
}

.hero-main {
  min-width: 0;
  flex: 1;
}

.hero-name-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-name {
  min-width: 0;
  color: #142033;
  font-size: 46rpx;
  line-height: 56rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-role {
  flex: none;
  max-width: 180rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #18c4b1, #06998c);
  font-size: 23rpx;
  line-height: 32rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-meta {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
  color: #34435b;
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.hero-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.hero-meta-icon {
  width: 26rpx;
  height: 26rpx;
  flex: none;
}

.stats {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.stat {
  min-width: 0;
  min-height: 132rpx;
  padding: 22rpx 8rpx 18rpx;
  border-radius: 20rpx;
  text-align: center;
}

.stat-icon-wrap {
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 10rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.stat-icon-img {
  width: 100%;
  height: 100%;
}

.stat-value {
  min-width: 0;
  color: #142033;
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  margin-top: 6rpx;
  color: #617087;
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.info-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
}

.card-title,
.card-title-row {
  color: #142033;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.card-title {
  display: flex;
  align-items: center;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.title-icon-img {
  width: 38rpx;
  height: 38rpx;
  margin-right: 12rpx;
  flex: none;
}

.section-count {
  flex: none;
  color: #08a895;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.section-count-icon {
  width: 28rpx;
  height: 28rpx;
}

.info-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.info-row {
  min-width: 0;
  min-height: 58rpx;
  padding: 12rpx 18rpx;
  border-radius: 12rpx;
  background: #f6f9fd;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  color: #142033;
  font-size: 25rpx;
  line-height: 34rpx;
}

.info-row text {
  min-width: 0;
  word-break: break-word;
}

.info-row text:first-child {
  flex: none;
  color: #708098;
}

.info-row text:last-child {
  text-align: right;
  font-weight: 800;
}

.paragraph {
  margin-top: 16rpx;
  color: #25344b;
  font-size: 27rpx;
  line-height: 46rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.media-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.media-cell {
  width: 100%;
  height: 86rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #dbfaf5 0%, #eff8ff 100%);
}

.media-cell.teal {
  background: linear-gradient(135deg, #d8fbf5 0%, #eaf9f7 100%);
}

.media-cell.purple {
  background: linear-gradient(135deg, #f2eaff 0%, #f8f2ff 100%);
}

.media-cell.blue {
  background: linear-gradient(135deg, #e8f3ff 0%, #f3f8ff 100%);
}

.media-img {
  width: 100%;
  height: 100%;
}

.file-cell {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #617087;
  font-size: 22rpx;
  font-weight: 800;
}

.certificate-row {
  margin-top: 14rpx;
  padding: 16rpx 0;
  border-top: 1rpx dashed #dfe8ed;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #25344b;
  font-size: 25rpx;
  line-height: 36rpx;
}

.certificate-row view {
  min-width: 0;
  word-break: break-word;
}

.performance {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx dashed #dfe8ed;
}

.performance-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.performance-customer {
  min-width: 0;
  color: #142033;
  font-size: 27rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.performance-score {
  flex: none;
  max-width: 360rpx;
  color: #f2a400;
  font-size: 23rpx;
  line-height: 32rpx;
  font-weight: 800;
  text-align: right;
}

.empty {
  margin-top: 28rpx;
  padding: 48rpx 28rpx;
  border-radius: 16rpx;
  background: #fff;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #142033;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #617087;
}
