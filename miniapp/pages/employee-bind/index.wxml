<view class="page">
  <view class="hero">
    <view class="hero-head">
      <view class="logo-box"><image class="logo" src="/assets/logo.png" mode="aspectFit" /></view>
      <view class="hero-copy">
        <view class="hero-title">绑定服务人员</view>
        <view class="hero-desc">绑定后可查看待签合同、填写月度考勤。</view>
      </view>
    </view>
    <view class="bind-tip">请使用后台登记的手机号和身份证后6位进行验证。</view>
  </view>

  <view class="card">
    <view class="field">
      <text class="label">登记手机号</text>
      <input class="input" type="number" placeholder="请输入后台登记手机号" value="{{form.phone_number}}" data-field="phone_number" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">身份证后6位</text>
      <input class="input" maxlength="6" placeholder="例如：123456 或 12345X" value="{{form.id_card_last6}}" data-field="id_card_last6" bindinput="onInput" />
    </view>
    <button class="btn-primary" loading="{{loading}}" bindtap="bindEmployee">确认绑定</button>
  </view>
</view>
