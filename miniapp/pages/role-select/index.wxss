.role-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow-x: hidden;
}

.role-title {
  text-align: center;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 900;
  color: #0f172a;
}

.role-desc {
  margin: 18rpx auto 42rpx;
  text-align: center;
  font-size: 27rpx;
  line-height: 42rpx;
  color: #64748b;
}

.role-card {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 18rpx;
  background: #e7f7f4;
  border: 1rpx solid #99d8ce;
}

.role-card.customer {
  background: #eef6ff;
  border-color: #bfdbfe;
}

.role-card-title {
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
  color: #0f172a;
}

.role-card-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #475569;
}
