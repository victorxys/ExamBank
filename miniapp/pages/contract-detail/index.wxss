.contract-detail-page {
  padding: 28rpx 24rpx 58rpx;
}

.detail-hero {
  position: relative;
  min-height: 190rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(174, 226, 219, 0.85);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 44rpx rgba(43, 118, 109, 0.08);
  box-sizing: border-box;
}

.detail-hero-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.detail-hero-icon,
.detail-hero-copy {
  position: relative;
  z-index: 1;
}

.detail-hero-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  color: #fff;
  background: linear-gradient(135deg, #35dfba, #08a895);
  font-size: 38rpx;
  line-height: 1;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(8, 168, 149, 0.18);
}

.detail-hero-copy {
  min-width: 0;
  flex: 1;
}

.hero-title {
  min-width: 0;
  color: #142033;
  font-size: 40rpx;
  line-height: 50rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-desc {
  margin-top: 8rpx;
  color: #40506a;
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.hero-dot {
  margin: 0 10rpx;
  color: #9aa7b8;
}

.date-range {
  margin-top: 10rpx;
  color: #526177;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 700;
}

.card {
  margin-top: 24rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(196, 228, 224, 0.86);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(43, 118, 109, 0.08);
  box-sizing: border-box;
}

.section-title {
  color: #142033;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.row {
  min-height: 66rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #dfe8ed;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  font-size: 26rpx;
  line-height: 36rpx;
}

.row:last-child {
  border-bottom: 0;
}

.row-label {
  flex: none;
  color: #617087;
  font-weight: 700;
}

.row-value {
  min-width: 0;
  color: #142033;
  text-align: right;
  font-weight: 900;
  word-break: break-word;
}

.attachment-block {
  max-height: 420rpx;
}

.notes-block {
  max-height: 360rpx;
}

.no-margin {
  margin-top: 0;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.eval-entry-link,
.text-entry-link {
  flex: none;
  padding-left: 24rpx;
  color: #0f9f8f;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 800;
  text-align: right;
}

.actions-card {
  overflow: hidden;
}

.staff-share-card {
  overflow: hidden;
}

.staff-share-desc {
  margin-top: 14rpx;
  color: #617087;
  font-size: 24rpx;
  line-height: 36rpx;
}

.staff-share-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  flex-wrap: wrap;
}

.staff-share-btn {
  margin: 0;
  min-width: 190rpx;
  height: 72rpx;
  padding: 0 26rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(135deg, #14cdb8, #029f92);
  font-size: 26rpx;
  line-height: 72rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(6, 166, 149, 0.2);
}

.staff-share-btn::after {
  border: 0;
}

.signing-message-panel {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f7fbfd;
  border: 1rpx solid #e1e9ef;
}

.signing-message-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.signing-message-title {
  color: #142033;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.signing-message-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-action {
  min-width: 72rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 1rpx solid #dce6eb;
  color: #526177;
  font-size: 23rpx;
  line-height: 32rpx;
  font-weight: 900;
}

.mini-action.primary {
  border-color: #b7eee5;
  background: #e8fbf7;
  color: #008d80;
}

.signing-message-tabs {
  margin-top: 18rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 6rpx;
  background: #eef4f7;
}

.signing-message-tab {
  height: 52rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #617087;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.signing-message-tab.active {
  background: #fff;
  color: #008d80;
  box-shadow: 0 8rpx 18rpx rgba(43, 118, 109, 0.08);
}

.signing-message-preview,
.signing-message-editor {
  width: 100%;
  min-height: 360rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #e3edf2;
  color: #26354c;
  font-size: 24rpx;
  line-height: 38rpx;
  white-space: pre-wrap;
  word-break: break-word;
  box-sizing: border-box;
}

.signing-message-editor {
  max-height: 720rpx;
}

.signing-message-empty {
  margin-top: 18rpx;
  padding: 34rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #718198;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}

.signing-message-empty.error {
  color: #b45309;
  background: #fff7ed;
}

.signing-message-footer {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  flex-wrap: wrap;
}

.outline-action,
.solid-action {
  min-width: 136rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 900;
}

.outline-action {
  background: #fff;
  border: 1rpx solid #dce6eb;
  color: #526177;
}

.solid-action {
  color: #fff;
  background: linear-gradient(135deg, #14cdb8, #029f92);
}

.notice-list {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 18rpx;
}

.notice-panel {
  padding: 24rpx;
  border-radius: 18rpx;
  border: 1rpx solid #d9efe9;
  background: #f0fdfa;
}

.notice-panel.warning {
  border-color: #fed7aa;
  background: #fff7ed;
}

.notice-main {
  min-width: 0;
}

.notice-kicker {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 159, 143, 0.12);
  color: #0f766e;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 900;
}

.notice-panel.warning .notice-kicker {
  background: #ffedd5;
  color: #c2410c;
}

.notice-title {
  margin-top: 14rpx;
  color: #0f172a;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 900;
  word-break: break-word;
}

.notice-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 36rpx;
  word-break: break-word;
}

.notice-btn {
  width: 100%;
  min-height: 82rpx;
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.notice-btn.primary {
  background: #0f9f8f;
  color: #fff;
}

.hint-line {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 34rpx;
}

.empty-line {
  margin-top: 18rpx;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 36rpx;
}

.error-card {
  border-color: #fed7aa;
  background: #fff7ed;
}

.error-text {
  margin-top: 18rpx;
  color: #9a3412;
  font-size: 26rpx;
  line-height: 42rpx;
  font-weight: 700;
}

.record-item {
  margin-top: 18rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.attendance-record-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #fff;
}

.attendance-record-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.record-main {
  min-width: 0;
  flex: 1;
}

.record-title {
  color: #0f172a;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.record-desc {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-word;
}

.record-status {
  flex: none;
  max-width: 180rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef7f4;
  color: #0f9f8f;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 800;
  text-align: center;
}

.record-status.danger {
  background: #fee2e2;
  color: #dc2626;
}

.record-status.signed {
  background: #ecfdf5;
  color: #047857;
}

.record-status.pending {
  background: #eef7f4;
  color: #0f9f8f;
}

.attendance-mini-stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.mini-stat {
  min-width: 0;
  padding: 18rpx 8rpx;
  border-radius: 14rpx;
  text-align: center;
}

.mini-stat.work {
  background: #e5faf6;
  color: #087c70;
}

.mini-stat.overtime {
  background: #fef3c7;
  color: #b45309;
}

.mini-stat.leave {
  background: #fee2e2;
  color: #dc2626;
}

.mini-stat-value {
  font-size: 32rpx;
  line-height: 38rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 800;
}

.md-block {
  max-height: 760rpx;
  padding-right: 4rpx;
  white-space: normal;
}

.signature-preview {
  height: 180rpx;
  margin-top: 18rpx;
  border: 2rpx dashed #d9e3ea;
  border-radius: 18rpx;
  background: #f8fafc;
  overflow: hidden;
}

.signature-image {
  width: 100%;
  height: 100%;
}
