.attendance-page {
  min-height: 100vh;
  padding: 0 10rpx 260rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.sticky-head {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 28rpx 24rpx 18rpx;
  background: rgba(248, 250, 252, 0.96);
  border-bottom: 1rpx solid #e5e7eb;
  backdrop-filter: blur(12rpx);
}

.head-sub {
  height: 42rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #64748b;
}

.head-main {
  display: grid;
  grid-template-columns: 56rpx 1fr 56rpx 72rpx;
  align-items: center;
  gap: 12rpx;
}

.month-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #eef2f7;
  color: #475569;
  font-size: 42rpx;
  font-weight: 800;
}

.month-btn.disabled {
  color: #cbd5e1;
  background: #f3f4f6;
}

.title-wrap {
  min-width: 0;
}

.page-title {
  font-size: 38rpx;
  line-height: 44rpx;
  font-weight: 900;
  color: #111827;
}

.status-line {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #e0e7ff;
  color: #4f46e5;
  font-size: 22rpx;
  font-weight: 900;
}

.stats-wrap {
  position: sticky;
  top: 138rpx;
  z-index: 18;
  padding: 16rpx 0 14rpx;
  background: #f8fafc;
}

.stats-panel {
  margin: 16rpx 0 14rpx;
  padding: 24rpx 10rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  background: #fff;
  border: 1rpx solid #edf0f4;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.05);
}

.stats-wrap .stats-panel {
  margin: 0;
}

.stat-col {
  text-align: center;
  border-right: 1rpx solid #eef2f7;
}

.stat-col:last-child {
  border-right: 0;
}

.stat-num {
  font-size: 42rpx;
  line-height: 48rpx;
  font-weight: 900;
  color: #111827;
}

.stat-num.orange {
  color: #f97316;
}

.stat-num.green {
  color: #16a34a;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #94a3b8;
}

.stat-sub {
  margin-top: 5rpx;
  font-size: 19rpx;
  line-height: 24rpx;
  color: #ef4444;
  font-weight: 800;
}

.calendar-card,
.detail-card,
.info-banner {
  margin-top: 14rpx;
  padding: 12rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid #edf0f4;
  box-shadow: 0 3rpx 14rpx rgba(15, 23, 42, 0.04);
}

.info-banner {
  padding: 22rpx;
  background: #ecfdf5;
  border-color: #bbf7d0;
}

.info-title {
  color: #064e3b;
  font-size: 26rpx;
  font-weight: 900;
}

.info-text {
  margin-top: 8rpx;
  color: #047857;
  font-size: 23rpx;
  line-height: 34rpx;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
}

.week-row {
  margin-bottom: 10rpx;
}

.week-cell {
  height: 32rpx;
  text-align: center;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 700;
}

.week-cell.red {
  color: #f87171;
}

.day-cell {
  position: relative;
  aspect-ratio: 1;
  min-height: 88rpx;
  padding: 8rpx 4rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: transform 0.15s ease;
}

.day-cell:active {
  transform: scale(0.96);
}

.day-cell.blank {
  border: 0;
  background: transparent;
}

.day-cell.disabled {
  opacity: 0.52;
  background: #f1f5f9;
}

.day-cell.auto-overtime {
  border-style: dashed;
}

.day-cell.today {
  box-shadow: 0 0 0 4rpx rgba(79, 70, 229, 0.18);
}

.day-cell.weekend {
  background: #fff1f2;
}

.day-cell.holiday {
  background: #fff1f2;
  border-color: #fecaca;
}

.day-cell.workday {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.holiday-badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 44rpx;
  height: 30rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 12rpx 0 10rpx;
  color: #fff;
  font-size: 17rpx;
  line-height: 30rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.holiday-badge.holiday {
  background: #ef4444;
}

.holiday-badge.workday {
  background: #2563eb;
}

.day-num {
  font-size: 32rpx;
  line-height: 34rpx;
  font-weight: 900;
  color: #334155;
}

.day-label {
  max-width: 100%;
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 22rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-disabled {
  margin-top: 4rpx;
  font-size: 28rpx;
  line-height: 28rpx;
  color: #94a3b8;
}

.day-time {
  max-width: 100%;
  margin-top: 3rpx;
  font-size: 17rpx;
  line-height: 20rpx;
  color: #94a3b8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tone-normal { background: #f8fafc; border-color: #e5e7eb; }
.tone-rest { background: #eff6ff; border-color: #bfdbfe; }
.tone-leave { background: #fefce8; border-color: #fde68a; }
.tone-overtime { background: #f0fdf4; border-color: #bbf7d0; }
.tone-out-beijing { background: #faf5ff; border-color: #e9d5ff; }
.tone-out-country { background: #fdf2f8; border-color: #fbcfe8; }
.tone-paid-leave { background: #eef2ff; border-color: #c7d2fe; }
.tone-onboarding { background: #ecfeff; border-color: #a5f3fc; }
.tone-offboarding { background: #fff1f2; border-color: #fecdd3; }

.tone-rest .day-label { color: #2563eb; }
.tone-leave .day-label { color: #ca8a04; }
.tone-overtime .day-label { color: #16a34a; }
.tone-out-beijing .day-label { color: #9333ea; }
.tone-out-country .day-label { color: #db2777; }
.tone-paid-leave .day-label { color: #4f46e5; }
.tone-onboarding .day-label { color: #0891b2; }
.tone-offboarding .day-label { color: #e11d48; }

.detail-card {
  padding: 22rpx;
}

.detail-title {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #334155;
}

.detail-row {
  margin-bottom: 14rpx;
  padding: 18rpx;
  display: grid;
  grid-template-columns: 118rpx 1fr;
  gap: 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border-left: 8rpx solid #cbd5e1;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.tone-left-rest { border-left-color: #60a5fa; }
.tone-left-leave { border-left-color: #facc15; }
.tone-left-overtime { border-left-color: #4ade80; }
.tone-left-out-beijing { border-left-color: #c084fc; }
.tone-left-out-country { border-left-color: #f472b6; }
.tone-left-paid-leave { border-left-color: #818cf8; }
.tone-left-onboarding { border-left-color: #22d3ee; }
.tone-left-offboarding { border-left-color: #fb7185; }

.detail-date {
  min-width: 0;
}

.detail-day {
  font-size: 24rpx;
  font-weight: 900;
  color: #111827;
}

.detail-type {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #64748b;
}

.detail-main {
  min-width: 0;
  text-align: right;
}

.detail-time {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #334155;
}

.detail-duration {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #111827;
}

.detail-duration.auto {
  color: #16a34a;
  font-size: 21rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 16rpx 24rpx 28rpx;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.readonly-bar {
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  text-align: center;
}

.readonly-title {
  color: #334155;
  font-size: 25rpx;
  font-weight: 900;
}

.readonly-text {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 22rpx;
}

.save-state {
  margin-bottom: 12rpx;
  text-align: center;
  color: #16a34a;
  font-size: 23rpx;
}

.save-state.saving {
  color: #64748b;
}

.save-state.error {
  color: #dc2626;
}

.submitted-hint {
  margin-bottom: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #ecfdf5;
  color: #047857;
  text-align: center;
  font-size: 23rpx;
  line-height: 32rpx;
}

.submit-btn,
.share-btn {
  width: 100%;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.submit-btn {
  background: #0f9f8f;
  color: #fff;
}

.submit-btn[disabled] {
  background: #cbd5e1;
  color: #64748b;
}

.share-btn {
  background: #16a34a;
  color: #fff;
}

.sheet-mask,
.time-mask {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.42);
  overflow: hidden;
}

.edit-sheet,
.time-sheet {
  width: calc(100% - 28rpx);
  margin: 0 14rpx;
  max-height: 88vh;
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  background: #fff;
  box-shadow: 0 -16rpx 40rpx rgba(15, 23, 42, 0.18);
}

.sheet-head {
  position: sticky;
  top: 0;
  z-index: 2;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  border-bottom: 1rpx solid #e5e7eb;
  background: #fff;
}

.sheet-head > view:first-child {
  min-width: 0;
  flex: 1;
}

.sheet-title {
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 900;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.holiday-title-badge {
  margin-top: 8rpx;
  padding: 5rpx 12rpx;
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  border-radius: 999rpx;
  color: #fff;
  font-size: 21rpx;
  line-height: 28rpx;
  font-weight: 900;
}

.holiday-title-badge.holiday {
  background: #ef4444;
}

.holiday-title-badge.workday {
  background: #2563eb;
}

.sheet-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.icon-close {
  width: 260rpx;
  max-width: 45%;
  height: 58rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 42rpx;
}

.type-grid {
  padding: 24rpx 30rpx 8rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.type-btn {
  min-width: 0;
  width: 100%;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dbe3ea;
  background: #fff;
  color: #111827;
  font-size: 25rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.type-btn.active {
  background: #111827;
  color: #fff;
  border-color: #111827;
}

.type-btn.disabled {
  opacity: 0.58;
}

.covering-alert {
  margin: 24rpx 30rpx 0;
  padding: 22rpx;
  border: 1rpx solid #fde68a;
  border-radius: 18rpx;
  background: #fffbeb;
  color: #92400e;
}

.holiday-alert {
  margin: 24rpx 30rpx 0;
  padding: 18rpx 20rpx;
  border: 1rpx solid #fecaca;
  border-radius: 16rpx;
  background: #fff1f2;
  color: #b91c1c;
  font-size: 23rpx;
  line-height: 34rpx;
  font-weight: 700;
}

.covering-title {
  font-size: 25rpx;
  font-weight: 900;
}

.covering-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 34rpx;
}

.time-panel {
  margin: 18rpx 30rpx 10rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  overflow: hidden;
}

.time-title {
  margin-bottom: 18rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #334155;
}

.hint-box {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #fde68a;
  border-radius: 14rpx;
  background: #fffbeb;
  color: #92400e;
  font-size: 24rpx;
}

.hint-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b45309;
}

.out-rule {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 14rpx;
  background: #eff6ff;
}

.out-title {
  color: #1e40af;
  font-size: 24rpx;
  font-weight: 900;
}

.out-text {
  margin-top: 6rpx;
  color: #2563eb;
  font-size: 22rpx;
  line-height: 32rpx;
}

.preset-row {
  margin-bottom: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.preset-btn {
  min-width: 0;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid #99f6e4;
  color: #0f766e;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.time-row {
  margin-bottom: 18rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.time-row > picker {
  min-width: 0;
  flex: 1;
}

.time-row.muted {
  background: #f1f5f9;
}

.time-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #64748b;
}

.time-value {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 900;
  color: #111827;
  text-align: right;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  overflow: hidden;
  text-overflow: ellipsis;
}

.time-value.date {
  max-width: 390rpx;
  text-align: right;
  font-family: inherit;
  font-size: 24rpx;
  line-height: 32rpx;
}

.duration-block {
  margin-bottom: 18rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #64748b;
  font-size: 23rpx;
}

.duration-row {
  margin-bottom: 18rpx;
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr) 92rpx;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  min-width: 0;
}

.step-btn {
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #111827;
  color: #fff;
  font-size: 46rpx;
  font-weight: 900;
}

.step-btn.disabled {
  background: #e2e8f0;
  color: #94a3b8;
}

.warn-text {
  margin-top: 10rpx;
  padding: 14rpx;
  border: 1rpx solid #fde68a;
  border-radius: 12rpx;
  background: #fffbeb;
  color: #b45309;
  font-size: 22rpx;
  line-height: 32rpx;
}

.duration-center {
  min-width: 0;
  text-align: center;
}

.duration-main {
  font-size: 46rpx;
  font-weight: 900;
  color: #111827;
}

.duration-sub {
  font-size: 22rpx;
  color: #64748b;
}

.duration-total {
  margin-top: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  color: #111827;
}

.sheet-actions {
  position: sticky;
  bottom: 0;
  padding: 22rpx 30rpx 30rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
}

.sheet-actions.single {
  grid-template-columns: 1fr;
}

.cancel-btn,
.confirm-btn {
  min-width: 0;
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  white-space: nowrap;
}

.cancel-btn {
  background: #f1f5f9;
  color: #334155;
}

.confirm-btn {
  background: #111827;
  color: #fff;
}

.time-sheet {
  padding-bottom: 32rpx;
}

.time-sheet-head {
  height: 92rpx;
  display: grid;
  grid-template-columns: 120rpx 1fr 120rpx;
  align-items: center;
  border-bottom: 1rpx solid #e5e7eb;
}

.picker-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  color: #111827;
}

.picker-cancel,
.picker-confirm {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  font-size: 26rpx;
}

.picker-cancel {
  color: #64748b;
}

.picker-confirm {
  color: #0f9f8f;
  font-weight: 900;
}

.picker-view {
  width: 100%;
  height: 420rpx;
}

.picker-item {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}
