page {
  min-height: 100%;
  background: #edf5f2;
  color: #17202a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  box-sizing: border-box;
  border-radius: 8rpx;
  line-height: 1.4;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero {
  padding: 30rpx;
  border-radius: 16rpx;
  color: #fff;
  background: linear-gradient(135deg, #21a99a, #4bba8f);
  box-shadow: 0 18rpx 40rpx rgba(16, 94, 82, 0.12);
}

.hero-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.logo-box {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #fff;
  flex-shrink: 0;
}

.logo {
  width: 54rpx;
  height: 54rpx;
}

.hero-title {
  font-size: 38rpx;
  line-height: 44rpx;
  font-weight: 800;
  word-break: break-word;
}

.hero-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: rgba(255, 255, 255, 0.86);
  word-break: break-word;
}

.card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.section-title {
  margin: 32rpx 0 18rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.muted {
  color: #64748b;
}

.btn-primary {
  width: 100%;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #0f9f8f;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.btn-secondary {
  height: 72rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d8e1e8;
  border-radius: 10rpx;
  background: #fff;
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
}

.input {
  height: 84rpx;
  padding: 0 22rpx;
  border-radius: 10rpx;
  border: 1rpx solid #d8e1e8;
  background: #fff;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx dashed #dbe4ea;
  font-size: 27rpx;
}

.row:last-child {
  border-bottom: none;
}

.row-label {
  flex-shrink: 0;
  color: #64748b;
}

.row-value {
  min-width: 0;
  text-align: right;
  font-weight: 700;
  color: #0f172a;
  word-break: break-all;
}

.empty {
  padding: 44rpx 28rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #64748b;
}

.chip {
  flex-shrink: 0;
  max-width: 132rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.text-block {
  max-height: 560rpx;
  overflow: auto;
  white-space: pre-wrap;
  word-break: break-word;
  font-size: 27rpx;
  line-height: 46rpx;
  color: #475569;
}

.signature-box {
  height: 260rpx;
  overflow: hidden;
  border: 1rpx dashed #cbd5e1;
  border-radius: 14rpx;
  background: #f8fafc;
}

.signature-canvas {
  width: 100%;
  height: 260rpx;
}
